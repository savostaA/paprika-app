{
  "name": "client",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "desktop:build": "npm run build && electron-builder --mac"
  },
  "dependencies": {
    "@capacitor/android": "8.3.4",
    "@capacitor/cli": "8.3.4",
    "@capacitor/core": "8.3.4",
    "@capacitor/ios": "8.3.4",
    "@capacitor/status-bar": "8.0.2",
    "lucide-react": "^1.17.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router-dom": "^7.16.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "electron": "^32.0.0",
    "electron-builder": "^24.13.0",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "vite": "^8.0.12"
  },
  "build": {
    "appId": "com.paprika.catering",
    "productName": "PaprikaCatering",
    "directories": {
      "output": "dist-desktop"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.food-and-drink",
      "target": [
        "zip"
      ],
      "icon": "electron/icon.png"
    }
  }
}
